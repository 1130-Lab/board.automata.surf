{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ModelBridge": {
    "GrpcEndpoint": "http://localhost:50051",
    "PrepareSessionTimeoutSeconds": 10,
    "WebSocketPath": "/ws"
  },
  "SessionStore": {
    "ReservationTtlSeconds": 30,
    "InactivityTimeoutSeconds": 300
  },
  "SessionTokens": {
    "Issuer": "board.automata.surf",
    "Audience": "board.automata.surf.session",
    "SigningKey": "dev-signing-key-change-this-value-32-bytes",
    "LifetimeSeconds": 120
  }
}
